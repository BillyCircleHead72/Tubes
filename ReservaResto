// 7
func makeReservation(r *reservations, nR *int, t *tables, nT int, c *customers, nC *int) {
	var targetTable, targetCustomer int
	var targetDate string
	var tFound, cFound, conflict bool

	fmt.Print("Enter Customer ID: ")
	fmt.Scan(&targetCustomer)

	//cek customer Id dah sudah terdaftar
	cFound = false
	i = 0
	for i < *nC && !cFound {
		if c[i].Id == targetCustomer {
			cFound = true
		}
		i++
	}

	//klo belum ada... langsung daftarkan customer Id di tempat!
	if !cFound {
		fmt.Printf("Customer ID %d not found. Creating new customer profile...\n", targetCustomer)

		//masukin ke array customers
		c[*nC].Id = targetCustomer
		fmt.Print("Please Enter Customer Name: ")
		fmt.Scan(&c[*nC].name)
		*nC++ //Naikin jumlah total customer

		fmt.Println("New customer profile created successfully!")
	}

	//Lanjut minta input data Table dan tanggal
	fmt.Print("Enter Table Number and Date (YYYY-MM-DD): ")
	fmt.Scan(&targetTable, &targetDate)

	//Cek table dah ada atau ga
	tFound = false
	i = 0
	for i < nT && !tFound {
		if t[i].num == targetTable {
			tFound = true
		}
		i++
	}

	if !tFound {
		fmt.Printf("\nError: Table number %d does not exist!\n", targetTable)
		return
	}
	//cek apakah jadwal bentrok
	conflict = false
	i = 0
	for i < *nR && !conflict {
		if r[i].tableNum == targetTable && r[i].date == targetDate {
			conflict = true
		}
		i++
	}

	//catat reservasi
	if conflict {
		fmt.Printf("\nFailed: Table %d is already reserved on %s!\n", targetTable, targetDate)
	} else {
		r[*nR].tableNum = targetTable
		r[*nR].customerId = targetCustomer
		r[*nR].date = targetDate
		*nR++

		//ubah status ketersediaan Table menjadi false (menunjukkan dah di reservasi)
		i = 0
		for i < nT {
			if t[i].num == targetTable {
				t[i].status = false
				t[i].rCount++
			}
			i++
		}
		fmt.Printf("\nReservation successful for Customer %d at Table %d on %s!\n", targetCustomer, targetTable, targetDate)
	}
}

// 8
func sequentialSearch(t tables, nT int, target, option int) {
	if option == 1 { /*kalo pilih search dengan nomor meja*/
		for i = 0; i < nT; i++ {
			if target == t[i].num {
				fmt.Printf("\nTable found!\nNumber: %d\nCapacity: %d\nStatus: %t\n", t[i].num, t[i].cap, t[i].status)
			}
		}
	} else { /*kalo pilih search dengan kapasitas meja*/
		for i = 0; i < nT; i++ {
			if target == t[i].cap {
				fmt.Printf("\nTable found!\nNumber: %d\nCapacity: %d\nStatus: %t\n", t[i].num, t[i].cap, t[i].status)
			}
		}
	}

}

// 9
func binarySearch(t tables, nT int, target, option int) {
	var left, mid, right int
	left = 0
	right = nT - 1
	mid = (left + right) / 2
	if option == 1 { /*kalo pilih search dengan nomor meja*/
		for left <= right {
			if t[mid].num > target {
				right = mid - 1
			} else if t[mid].num < target {
				left = mid + 1
			} else {
				fmt.Printf("\nTable found!\nNumber: %d\nCapacity: %d\nStatus: %t\n", t[mid].num, t[mid].cap, t[mid].status)
				left = right + 1
			}
			mid = (left + right) / 2
		}
	} else { /*kalo pilih search dengan kapasitas meja*/
		for left <= right {
			if t[mid].cap > target {
				right = mid - 1
			} else if t[mid].cap < target {
				left = mid + 1
			} else {
				fmt.Printf("\nTable found!\nNumber: %d\nCapacity: %d\nStatus: %t\n", t[mid].num, t[mid].cap, t[mid].status)
				left = right + 1
			}
			mid = (left + right) / 2
		}
	}

}

// 10
func selectionSortAscend(t *tables, nT int) {
	var j, min int
	var temp table
	for i = 1; i < nT; i++ {
		min = i - 1
		for j = i; j < nT; j++ {
			if t[min].cap > t[j].cap {
				min = j
			}
		}
		temp = t[min]
		t[min] = t[i-1]
		t[i-1] = temp
	}
}

// 11
func insertionSortAscend(t *tables, nT int) {
	var j int
	var temp table
	for i = 1; i < nT; i++ {
		temp = t[i]
		j = i - 1
		for j >= 0 && temp.cap < t[j].cap {
			t[j+1] = t[j]
			j = j - 1
		}
		t[j+1] = temp
	}
}

