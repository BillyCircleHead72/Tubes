package main

import "fmt"

const nMax int = 100

type table struct {
	num, cap, rCount int
	status           bool
	//true = available, false = reserved
}

type customer struct {
	Id   int
	name string
}

type reservation struct {
	tableNum, customerId int
	date                 string
}

type tables [nMax]table
type customers [nMax]customer
type reservations [nMax]reservation

var nT, nC, nR, i int

// 1
func addTable(t *tables, nT *int) {
	fmt.Scan(&t[*nT].num, &t[*nT].cap)
	t[*nT].status = true
	fmt.Printf("\nTable added successfully!\n")
	*nT++
}

// 2
func changeTableData(t *tables, nT int, target int) {
	var newNum, newCap int
	var valid bool
	i = 0
	valid = true
	fmt.Print("Please Input New Table Number and Capacity: ")
	fmt.Scan(&newNum, &newCap)
	//range if teh ngecek kalau yg mau diubah terdaftar ato ga indeksnya
	if target >= 0 && target < nT {
		for i < nT && valid {
			if i != target && newNum == (*t)[i].num {
				fmt.Printf("\nTable already exists\n")
				valid = false
			}
			i++
		}

		if valid {
			(*t)[target].num = newNum
			(*t)[target].cap = newCap
			(*t)[target].status = true
			fmt.Printf("\nTable data changed!\n")
		}
	} else {
		fmt.Printf("\nTable doesn't exist\n")
	}
}

// 3
func deleteTable(t *tables, nT *int, target int) {
	if target >= 0 && target < *nT {
		fmt.Printf("\nDeleting Table Number %d\n", t[target].num)
		for i = target; i < *nT-1; i++ {
			(*t)[i] = (*t)[i+1] /*geser SEMUA indeks depannya ke belakang 1x*/
		}
		*nT--
		fmt.Printf("\nTable Data with id no.%d deleted successfully!\n", target)

	} else {
		fmt.Printf("\nTable doesn't exist\n")
	}
}

